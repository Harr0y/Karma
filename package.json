    "drizzle-orm": "^0.39.3",
    "glob": "^13.0.3",
    "gray-matter": "^4.0.3",
    "lunar-javascript": "^1.7.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/runner": "^4.0.18",
    "@vitest/snapshot": "^4.0.18",
