# Karma 环境变量配置 - 测试环境
# 复制此文件为 .env.test 并填写实际值
#
# 使用方式:
# docker-compose -f docker-compose.test.yml --env-file .env.test up

# === AI API 配置 ===
ANTHROPIC_AUTH_TOKEN=your-test-api-token-here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_MODEL=glm-5

# === Telegram 配置 (测试 Bot) ===
# 注意: 测试环境应使用独立的测试 Bot
TELEGRAM_BOT_TOKEN=
